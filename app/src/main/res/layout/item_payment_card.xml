<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Selected Indicator -->
        <ImageView
            android:id="@+id/selectedIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_check_circle"
            android:tint="@color/colorPrimary"
            android:visibility="gone" />

        <!-- Payment Icon -->
        <ImageView
            android:id="@+id/paymentIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <!-- Payment Details Container -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/selectedIcon"
            android:layout_toEndOf="@id/paymentIcon"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/paymentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/payment_method"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/paymentDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/account_details"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp" />

            <!-- Payment Extra (for additional info like "JazzCash Account") -->
            <TextView
                android:id="@+id/paymentExtra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <!-- Default Badge -->
            <TextView
                android:id="@+id/defaultBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dafault"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:background="#E3F2FD"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Set Default Button -->
        <ImageView
            android:id="@+id/setDefaultButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_below="@id/contentLayout"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_star_border"
            android:tint="@color/grey_400"
            android:background="?selectableItemBackgroundBorderless"
            android:padding="2dp"
            android:visibility="gone" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>