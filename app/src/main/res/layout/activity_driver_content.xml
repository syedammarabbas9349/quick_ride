<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map Fragment -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#80000000">

        <Button
            android:id="@+id/settings"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Settings"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/logout"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Logout" />
    </LinearLayout>

    <!-- Online/Offline Switch -->
    <Switch
        android:id="@+id/workingSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar"
        android:layout_margin="16dp"
        android:text="Online" />

    <!-- Pull Up Handle -->
    <LinearLayout
        android:id="@+id/bringUpBottomLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:background="@drawable/bottom_sheet_handle"
            android:layout_marginBottom="4dp" />

        <!-- RENAMED: Changed from customerName to pullUpCustomerName -->
        <TextView
            android:id="@+id/pullUpCustomerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Active Ride"
            android:textSize="14sp"
            android:textColor="#757575" />
    </LinearLayout>

    <!-- Bottom Sheet -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:visibility="gone"
        android:padding="16dp">

        <!-- Customer Info -->
        <LinearLayout
            android:id="@+id/customerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Ride"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/customerProfileImage"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/default_profile"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <!-- KEPT: This one keeps the original ID -->
                    <TextView
                        android:id="@+id/customerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Customer Name"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pickupAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup Location"
                        android:textSize="14sp"
                        android:textColor="#757575"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/openMaps"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Navigate"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/phone"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Call" />
            </LinearLayout>

            <Button
                android:id="@+id/cancel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Cancel Ride"
                android:backgroundTint="#F44336" />
        </LinearLayout>

        <!-- Ride Requests Section -->
        <LinearLayout
            android:id="@+id/requestsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nearby Requests"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <ListView
                android:id="@+id/requestsListView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@null"
                android:dividerHeight="0dp" />

            <TextView
                android:id="@+id/noRequestsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No ride requests available"
                android:textSize="14sp"
                android:textColor="#757575"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Ride Status Section -->
        <LinearLayout
            android:id="@+id/rideStatusSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/rideStatus"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Pickup Customer" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>